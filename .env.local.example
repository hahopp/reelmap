# ReelMap 환경변수 — 이 파일을 복사해 `.env.local` 로 만들고 값 채우기
# (.env.local 은 git 에 올라가지 않음 / 이 example 파일만 추적됨)

# ── Supabase ──────────────────────────────────────────────
# Supabase 대시보드 > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 서버 전용(시드 스크립트/어드민 server action). 절대 클라이언트 노출 금지.
SUPABASE_SERVICE_ROLE_KEY=

# ── 카카오 (지도 표시 = JS 키 / 장소검색 = REST 키) ──────────
# Kakao Developers > 내 애플리케이션 > 앱 키
NEXT_PUBLIC_KAKAO_MAP_JS_KEY=
# 서버 전용(로컬 키워드 장소검색)
KAKAO_REST_API_KEY=

# ── 어드민 게이트 ─────────────────────────────────────────
# /admin 접근용 비밀번호 (서버 전용)
ADMIN_PASSWORD=

# ── 인제스트 파이프라인 (ADR 0002) ────────────────────────
# AI 정제(Claude) — 서버 전용. https://console.anthropic.com
ANTHROPIC_API_KEY=
# capture API(/api/captures) Bearer 토큰 — 외부 에이전트 인증. 서버 전용. 길고 무작위로.
INGEST_API_TOKEN=

# ── PostHog (Phase 5에서 연동) ────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
